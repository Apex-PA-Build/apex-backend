# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=APEX
APP_ENV=development        # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://apex:apex_pass@localhost:5432/apex_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_DEFAULT=3600       # seconds

# ─── Vector Store (Qdrant) ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_MEMORY=apex_memory

# ─── LLM (Anthropic) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Encryption (for OAuth tokens stored in DB) ──────────────────────────────
ENCRYPTION_KEY=base64-encoded-32-byte-fernet-key

# ─── OAuth Integrations ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/callback/google

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/callback/slack

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/v1/integrations/callback/notion

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─── PA-to-PA Agent ──────────────────────────────────────────────────────────
AGENT_MESSAGE_TTL_DAYS=30
AGENT_AUTO_RESPOND=false
